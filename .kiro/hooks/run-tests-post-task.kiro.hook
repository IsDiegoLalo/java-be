{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Runs the test suite after a spec task is completed to ensure changes don't break existing functionality.",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "if [ -f \"./gradlew\" ]; then ./gradlew test --quiet 2>&1 | tail -30; elif [ -f \"./mvnw\" ]; then ./mvnw test -q 2>&1 | tail -30; elif command -v gradle &> /dev/null; then gradle test --quiet 2>&1 | tail -30; elif command -v mvn &> /dev/null; then mvn test -q 2>&1 | tail -30; else echo \"No build tool found\"; fi"
  }
}